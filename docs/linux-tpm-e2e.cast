{"version": 2, "width": 120, "height": 45, "timestamp": 1774607544, "env": {"SHELL": "/bin/bash", "TERM": null}, "title": "AgentPay Linux TPM 2.0 E2E Demo"}
[0.001726, "o", "╔══════════════════════════════════════════════════════════╗\r\n║  AgentPay Linux TPM 2.0 Signer Backend — E2E Demo       ║\r\n╚══════════════════════════════════════════════════════════╝\r\n\r\n"]
[1.002211, "o", "▸ Step 1: Verify TPM hardware\r\n  $ ls -la /dev/tpmrm0\r\n"]
[1.002726, "o", "crw------- 1 root root 253, 65536 Mar 27 17:45 /dev/tpmrm0\r\n"]
[1.002852, "o", "\r\n"]
[2.003239, "o", "▸ Step 2: Start daemon (--signer-backend tpm)\r\n"]
[2.003288, "o", "  $ agentpay-daemon --signer-backend tpm --tpm-device /dev/tpmrm0\r\n"]
[5.004036, "o", "  ✓ Daemon running (PID 9677)\r\n\r\n"]
[6.004764, "o", "▸ Step 3: Bootstrap (TPM seal vault key + agent key)\r\n  $ agentpay-admin bootstrap --print-agent-auth-token\r\n"]
[6.006616, "o", "==> initializing daemon\r\n==> issuing admin lease\r\n"]
[6.311269, "o", "==> registering spending policies\r\n"]
[7.884267, "o", "==> creating vault and agent keys\r\n"]
[8.187546, "o", "==> bootstrap complete\r\nState File: daemon_socket:/tmp/tpm-demo/socket/daemon.sock\r\nLease\r\n  ID: 2abbb245-9b3a-425c-95a6-1e5ebbf44ae3\r\n  Expires At: 2026-03-27T11:02:30.509010058Z\r\n  Agent Policy Attachment: policy_set\r\nKeys\r\n  Vault Key ID: e2fc837a-bfd8-4cc5-a331-66689bf863bf\r\n  Vault Public Key: 04a566176408901c10e96389b040a7e7fc1e8d252e5ea711ef0b3b9498e118571977a445955219abfdf8560562e182e069e6751674d37bd0268826e5cb6f86d107\r\n  Agent Key ID: f793266f-cdd1-4872-8c13-af1ba2ba8418\r\n  Agent Auth Token: 3eaa7a37af6c4b4f851131404abfaf51.64191d0a56ab4966928a0ffd51a0a9ee\r\nPolicies\r\n  Per-Tx: 4e9938ff-86a6-4172-a964-38677508d897\r\n  Daily: bfeaea10-4e75-4a80-a48e-58e6c9743587\r\n  Weekly: f40a6d6f-d41d-48e2-84e5-76f6fcbe2be9\r\n  Per-Chain Max Gas: 9f5dc28b-6693-41a9-9b33-c6d4e4c7da54\r\n  Per-Tx Limit (wei): 1000000000000000000\r\n  Daily Limit (wei): 5000000000000000000\r\n  Weekly Limit (wei): 20000000000000000000\r\n  Per-Chain Max Gas Limit (wei): 1000000000000000\r\n  Network Scope: all networks\r\n  Asset Scope: all assets\r\n  Recipient Scope: all recipients\r\n  Destination Override Count: 0\r\n  Warning: keep the agent auth token and any exported private key carefully.\r\nAttached Policy IDs\r\n  4e9938ff-86a6-4172-a964-38677508d897\r\n  9f5dc28b-6693-41a9-9b33-c6d4e4c7da54\r\n  bfeaea10-4e75-4a80-a48e-58e6c9743587\r\n  f40a6d6f-d41d-48e2-84e5-76f6fcbe2be9\r\nPolicy Note\r\n  agent key is attached to 4 bootstrap-created policy id(s)\r\n"]
[8.190352, "o", "\r\n"]
[8.190397, "o", "  → Agent Key: f793266f-cdd1-4872-8c13-af1ba2ba8418\r\n  → Vault PubKey (secp256k1): 04a566176408901c10e9...e5cb6f86d107\r\n"]
[8.190481, "o", "  → Public key length: 65 bytes (uncompressed secp256k1)\r\n\r\n"]
[10.191011, "o", "▸ Step 4: List spending policies\r\n"]
[10.191062, "o", "  $ agentpay-admin list-policies\r\n"]
[10.192762, "o", "==> issuing admin lease\r\n"]
[10.497072, "o", "==> listing policies\r\n"]
[10.800822, "o", "Policy ID: 4e9938ff-86a6-4172-a964-38677508d897\r\nPriority: 1000\r\nType: per_tx_max_spending\r\nEnabled: true\r\nNetworks: all networks\r\nAssets: all assets\r\nRecipients: all recipients\r\nMax Amount (wei): 1000000000000000000\r\n\r\nPolicy ID: bfeaea10-4e75-4a80-a48e-58e6c9743587\r\nPriority: 1001\r\nType: daily_max_spending\r\nEnabled: true\r\nNetworks: all networks\r\nAssets: all assets\r\nRecipients: all recipients\r\nMax Amount (wei): 5000000000000000000\r\n\r\nPolicy ID: f40a6d6f-d41d-48e2-84e5-76f6fcbe2be9\r\nPriority: 1002\r\nType: weekly_max_spending\r\nEnabled: true\r\nNetworks: all networks\r\nAssets: all assets\r\nRecipients: all recipients\r\nMax Amount (wei): 20000000000000000000\r\n\r\nPolicy ID: 9f5dc28b-6693-41a9-9b33-c6d4e4c7da54\r\nPriority: 1003\r\nType: per_chain_max_gas_spend\r\nEnabled: true\r\nNetworks: all networks\r\nAssets: all assets\r\nRecipients: all recipients\r\nMax Gas Spend (wei): 1000000000000000\r\n"]
[10.801382, "o", "\r\n"]
[12.802473, "o", "▸ Step 5: Broadcast EIP-1559 tx (Sepolia, TPM key signs secp256k1)\r\n  $ agentpay-agent broadcast --network 11155111 --to 0x...0001 --value-wei 1000000000000000\r\n"]
[12.812778, "o", "{\r\n  \"command\": \"broadcast\",\r\n  \"network\": \"11155111\",\r\n  \"asset\": \"native_eth\",\r\n  \"counterparty\": \"0x0000000000000000000000000000000000000001\",\r\n  \"amount_wei\": \"1000000000000000\",\r\n  \"estimated_max_gas_spend_wei\": \"630000000000000\",\r\n  \"tx_type\": \"0x02\",\r\n  \"delegation_enabled\": false,\r\n  \"signature_hex\": \"0x3045022100f251ef0dbcdad6168bfa3c35c77d6ee86d52ccc22b4574095cf51241396c54c902202da8068cfc77894d48c7c25550fbccbd6d66cb6ad70f9e59fdfb6c7ecaa02db1\",\r\n  \"r_hex\": \"0xf251ef0dbcdad6168bfa3c35c77d6ee86d52ccc22b4574095cf51241396c54c9\",\r\n  \"s_hex\": \"0x2da8068cfc77894d48c7c25550fbccbd6d66cb6ad70f9e59fdfb6c7ecaa02db1\",\r\n  \"v\": 0,\r\n  \"raw_tx_hex\": \"0x02f87583aa36a780843b9aca008506fc23ac0082520894000000000000000000000000000000000000000187038d7ea4c6800080c080a0f251ef0dbcdad6168bfa3c35c77d6ee86d52ccc22b4574095cf51241396c54c9a02da8068cfc77894d48c7c25550fbccbd6d66cb6ad70f9e59fdfb6c7ecaa02db1\",\r\n  \"tx_hash_hex\": \"0x3293add383b31be292ef989a8185ff5a88a3262318b06e63dd564f8aab1f4d1e\"\r\n}\r\n"]
[12.813029, "o", "\r\n"]
[14.813598, "o", "▸ Step 6: Transfer-native (policy-checked)\r\n  $ agentpay-agent transfer-native --network 11155111 --amount-wei 500000000000000\r\n"]
[14.818355, "o", "{\r\n  \"command\": \"transfer-native\",\r\n  \"network\": \"11155111\",\r\n  \"asset\": \"native_eth\",\r\n  \"counterparty\": \"0x0000000000000000000000000000000000000001\",\r\n  \"amount_wei\": \"500000000000000\",\r\n  \"signature_hex\": \"0x3043021f37d73040ef1d13bfb01dac6183934da4ec95fec3b29def38a34f0bd0e24d6a0220749713d07e0ca0e9873e7dd70e7aacc5af5dc2cea8f5c8360d836e812d148460\"\r\n}\r\n"]
